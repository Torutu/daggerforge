# Copy this file to .env.local and set your Obsidian vault path.
# .env.local is git-ignored — never commit it.
#
# WSL2 format (Linux path to the Windows vault):
OBSIDIAN_VAULT=/mnt/c/Users/yourname/Documents/your-vault
#
# Windows format (only used by deploy.ps1 if run directly):
# OBSIDIAN_VAULT=C:\Users\yourname\Documents\your-vault
